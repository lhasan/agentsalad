{
  "name": "agentsalad",
  "version": "0.0.0",
  "description": "Multi-provider AI agent platform served through messenger channels.",
  "license": "Elastic-2.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "postinstall": "npx playwright install chromium",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:electron": "tsc -p electron/tsconfig.json && node -e \"require('fs').writeFileSync('dist-electron/package.json','{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "electron": "npm run build:electron && node electron/launch.cjs",
    "electron:dev": "npm run build:electron && node electron/launch.cjs",
    "electron:node": "node scripts/download-node.cjs",
    "electron:build": "npm run build && npm run build:electron && npm run electron:node && electron-builder"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "ai": "^6.0.116",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "grammy": "^1.41.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.58.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "com.agentsalad.desktop",
    "productName": "Agent Salad",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "electron/renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "build/node",
        "to": "node"
      },
      {
        "from": "dist",
        "to": "app-server/dist"
      },
      {
        "from": "node_modules",
        "to": "app-server/node_modules",
        "filter": [
          "**/*",
          "!**/playwright/.local-browsers/**"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asarUnpack": [
      "**/better-sqlite3/**"
    ]
  }
}
